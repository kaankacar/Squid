PORT=3000
NODE_ENV=development

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# OpenZeppelin Defender Configuration (REQUIRED)
# Get your API credentials from: https://defender.openzeppelin.com/
DEFENDER_API_KEY=your_defender_api_key
DEFENDER_API_SECRET=your_defender_api_secret
DEFENDER_RELAYER_ID=your_relayer_id

# Protocol Fee Address (receives 5% pulse fee)
PROTOCOL_FEE_ADDRESS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Transaction Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000
TX_TIMEOUT_SECONDS=30
MEMO_REQUIRED=false

# Logging
LOG_LEVEL=info
LOG_FILE=logs/relayer.log

# Legacy Configuration (DEPRECATED - Not used with Defender)
# RELAYER_SECRET_KEY=  # Use Defender Relayer instead
# STELLAR_RPC_URL=     # Defender provides RPC access
